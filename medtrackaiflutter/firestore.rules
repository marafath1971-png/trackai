rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper: Is the caller an active caregiver of this user? ────────
    function isActiveCaregiver(userId) {
      return exists(/databases/$(database)/documents/users/$(userId)/caregivers/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(userId)/caregivers/$(request.auth.uid)).data.status == 'active';
    }

    // ── Helper: Is an invite code still within its 24-hour window? ─────
    function isInviteValid() {
      return request.time < resource.data.createdAt + duration.value(86400, 's');
    }

    // ── User Data (Owner & Caregiver access) ──────────────────────────
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read: if request.auth != null && isActiveCaregiver(userId);

      match /medicines/{medId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
        allow read: if request.auth != null && isActiveCaregiver(userId);
      }

      match /history/{dateKey} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
        allow read: if request.auth != null && isActiveCaregiver(userId);
      }

      match /caregivers/{cgKey} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
        allow read: if request.auth != null && request.auth.uid == cgKey;
        // Allow caregiver to set/update their own status during join flow
        allow create, update: if request.auth != null && request.auth.uid == cgKey
                      && request.resource.data.status == 'active';
      }

      // Monitoring List: Owned by the caregiver to track their patients
      match /monitoring/{patientId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      // Recursive rule for sub-paths in monitoring if needed
      match /monitoring/{allPaths=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /symptoms/{symptomId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
        allow read: if request.auth != null && isActiveCaregiver(userId);
      }
    }

    // ── Caregiver Invites ───────────────────────────────────────────────
    match /caregiverInvites/{inviteCode} {
      allow read:   if request.auth != null && isInviteValid();
      allow create: if request.auth != null
                    && request.resource.data.patientUid == request.auth.uid;
      allow delete: if request.auth != null
                    && resource.data.patientUid == request.auth.uid;
    }

    // ── Deny everything else ────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper: Is the caller an active caregiver of this user? ────────
    function isActiveCaregiver(userId) {
      return exists(/databases/$(database)/documents/users/$(userId)/caregivers/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(userId)/caregivers/$(request.auth.uid)).data.status == 'active';
    }

    // ── Helper: Is an invite code still within its 24-hour window? ─────
    function isInviteValid() {
      return request.time < resource.data.createdAt + duration.value(86400, 's');
    }

    // ── User root document (profile, takenToday, streakData, darkMode) ─
    match /users/{userId} {
      allow read:  if request.auth != null
                   && (request.auth.uid == userId || isActiveCaregiver(userId));
      allow write: if request.auth != null && request.auth.uid == userId;

      // ── Medicines subcollection ─────────────────────────────────────
      match /medicines/{medId} {
        allow read:  if request.auth != null
                     && (request.auth.uid == userId || isActiveCaregiver(userId));
        allow write: if request.auth != null && request.auth.uid == userId;
      }

      // ── History subcollection ───────────────────────────────────────
      match /history/{dateKey} {
        allow read:  if request.auth != null
                     && (request.auth.uid == userId || isActiveCaregiver(userId));
        allow write: if request.auth != null && request.auth.uid == userId;
      }

      // ── Caregivers subcollection ────────────────────────────────────
      // Patient can read/write all caregiver docs.
      // The caregiver themselves can read their own doc and update their status to 'active'.
      match /caregivers/{cgId} {
        allow read:  if request.auth != null
                     && (request.auth.uid == userId || request.auth.uid == cgId);
        allow create: if request.auth != null && request.auth.uid == userId;
        allow update: if request.auth != null
                      && (
                        request.auth.uid == userId
                        || (
                          request.auth.uid == cgId
                          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])
                          && request.resource.data.status == 'active'
                        )
                      );
        allow delete: if request.auth != null && request.auth.uid == userId;
      }
    }

    // ── Caregiver Invites ───────────────────────────────────────────────
    // Only a signed-in user can create an invite for THEIR OWN UID.
    // Any signed-in user can read a valid (non-expired) invite (to join).
    // Only the patient who owns the invite can delete it.
    match /caregiverInvites/{inviteCode} {
      allow read:   if request.auth != null && isInviteValid();
      allow create: if request.auth != null
                    && request.resource.data.patientUid == request.auth.uid;
      allow delete: if request.auth != null
                    && resource.data.patientUid == request.auth.uid;
      // No arbitrary updates allowed — create/delete only.
      allow update: if false;
    }

    // ── Deny everything else ────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
